<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light=#F2F2F2, Dark=#1A1A1A}">

    <ContentPage.BindingContext>
        <vm:MainViewModel />
    </ContentPage.BindingContext>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Profile" Command="{Binding NavigateToProfileCommand}"/>
        <ToolbarItem Text="Logout" Command="{Binding LogoutCommand}"/>
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshDataCommand}">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0">

                <!-- Welcome Header -->
                <Border BackgroundColor="#1877F2"
                        StrokeThickness="0"
                        Padding="24,32">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding WelcomeMessage}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"/>
                        <Label Text="{Binding CurrentUser.Email}"
                               FontSize="14"
                               TextColor="White"
                               Opacity="0.8"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Error Display -->
                <Border BackgroundColor="#FFEBEE"
                        StrokeThickness="0"
                        Padding="16"
                        Margin="16,12,16,0"
                        IsVisible="{Binding HasError}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout>
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#D32F2F"
                               FontSize="14"
                               VerticalOptions="Center"
                               HorizontalOptions="StartAndExpand"/>
                        <Button Text="X"
                                Command="{Binding ClearErrorCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#D32F2F"
                                FontSize="16"
                                Padding="5"
                                WidthRequest="30"
                                HeightRequest="30"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Quick Actions Label -->
                <Label Text="Quick Actions"
                       FontSize="20"
                       FontAttributes="Bold"
                       Margin="20,20,20,12"
                       TextColor="{AppThemeBinding Light=#222222, Dark=White}"/>

                <!-- Browse Items Card -->
                <Border Margin="16,0,16,10"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                        StrokeThickness="0"
                        Padding="20"
                        HeightRequest="80">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,1" Radius="4" Opacity="0.2"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToItemsCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Browse Items"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=White}"/>
                            <Label Text="Find items to rent nearby"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text=">"
                               FontSize="20"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"/>
                    </Grid>
                </Border>

                <!-- My Rentals Card -->
                <Border Margin="16,0,16,10"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                        StrokeThickness="0"
                        Padding="20"
                        HeightRequest="80">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,1" Radius="4" Opacity="0.2"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToRentalsCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="My Rentals"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=White}"/>
                            <Label Text="View incoming and outgoing requests"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text=">"
                               FontSize="20"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"/>
                    </Grid>
                </Border>

                <!-- Profile Card -->
                <Border Margin="16,0,16,10"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                        StrokeThickness="0"
                        Padding="20"
                        HeightRequest="80">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,1" Radius="4" Opacity="0.2"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToProfileCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="Profile Settings"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=White}"/>
                            <Label Text="Manage your account information"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text=">"
                               FontSize="20"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"/>
                    </Grid>
                </Border>

                <!-- User Management Card (Admin Only) -->
                <Border Margin="16,0,16,10"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                        StrokeThickness="0"
                        Padding="20"
                        HeightRequest="80"
                        IsVisible="{Binding IsAdmin}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,1" Radius="4" Opacity="0.2"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToUserListCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="User Management"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=White}"/>
                            <Label Text="Manage users and their roles"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text=">"
                               FontSize="20"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"/>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
